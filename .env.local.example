# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; never commit real keys.

# Anthropic (Claude) — used server-side for moment matching + caption generation (Phase 4)
ANTHROPIC_API_KEY=

# AssemblyAI — used server-side for transcription with speaker labels (Phase 3)
ASSEMBLYAI_API_KEY=

# Supabase — auth, Postgres, and video storage
# Found in your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key: SERVER ROUTES ONLY, never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=
